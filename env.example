# Optional. Without this key the app still supports Polymarket and demo mode.
THE_ODDS_API_KEY=

# The Odds API refresh cadence (seconds). Lower = fresher sportsbook lines but
# more paid API credits. Polymarket streams in real time regardless of this.
ODDS_POLL_SECONDS=20
ODDS_REGIONS=us
ODDS_MARKETS=h2h,spreads,totals
ODDS_BOOKMAKERS=
# Player props (per-event endpoint only; needs an odds_api_event_id). Off by
# default — set the sport's market keys to enable, e.g.
# player_points,player_rebounds,player_assists (an unsupported key returns 422).
ODDS_PLAYER_MARKETS=

SIGNAL_CONFIDENCE_THRESHOLD=72
SIGNAL_EDGE_THRESHOLD=0.035
MAX_DATA_AGE_SECONDS=20
# Fractional Kelly stake (0.25 = quarter-Kelly) and the required-edge
# z-multiplier on consensus uncertainty (higher = more conservative gating).
SIGNAL_KELLY_FRACTION=0.25
SIGNAL_EDGE_Z=1.0
