# Optional paid sportsbook feed. Polymarket discovery and market data need no key.
THE_ODDS_API_KEY=
# Keep this below MAX_DATA_AGE_SECONDS; shorter polling uses more API credits.
ODDS_POLL_SECONDS=45
ODDS_REGIONS=us
ODDS_MARKETS=h2h,spreads,totals
ODDS_BOOKMAKERS=
ODDS_PLAYER_MARKETS=

# Optional reviewed v2 artifact built from chronological out-of-sample data.
# With no artifact (the default), consensus remains display-only WATCH.
CALIBRATION_ARTIFACT=
# Separately reviewed exact-segment sport-model registry. The flag alone cannot
# expose independent output, and no artifact ships with the repository.
INDEPENDENT_MODEL_ARTIFACT=
ENABLE_INDEPENDENT_MODELS=false

# Global engine floors run before bot-specific strategy checks. Keep these at
# zero so paper-bot strategies can enforce their own thresholds.
SIGNAL_CONFIDENCE_THRESHOLD=0
SIGNAL_EDGE_THRESHOLD=0
MAX_DATA_AGE_SECONDS=120
SIGNAL_KELLY_FRACTION=0.25

# Opt-in paper-harness override. When true, bots may trade signals the engine
# holds at WATCH *solely* because no validated calibration artifact is installed.
# The edge used is the uncalibrated gross consensus gap; every other gate still
# applies (>=2 independent references, clean full-depth fill, edge above floor),
# so single-source markets (e.g. Polymarket-only tennis/esports) still never
# trade. Leave false for validated-only behavior.
PAPER_ALLOW_UNCALIBRATED=false

# Opt-in independent in-play tennis model. When true, tennis moneylines get a
# real win probability derived from the live set/game score, anchored to the
# market's pre-match price (captured at match start). Bots trade the edge of
# that model vs the executable price, so tennis can trade a genuine edge
# despite having no reference-book feed. Serve-neutral, best-of-three by
# default; joins mid-match get no anchor and are skipped.
ENABLE_TENNIS_MODEL=false

# Optional PostgreSQL DSN for all persistent stores. When blank, local SQLite
# uses LEDGER_DB for positions/accounts/monitor state and HISTORY_DB for quotes.
DATABASE_URL=
LEDGER_DB=ledger.db
HISTORY_DB=history.db
# Age cap for the decision-audit log (decision_marks). Old rows are pruned so a
# small managed database (e.g. a 500 MB Supabase free tier) cannot fill up. The
# large per-decision input snapshot is stored only for actual PAPER_BET rows.
DECISION_MARKS_RETENTION_DAYS=7
# Optional separate SQLite file for tracked events and auto-monitor settings.
# STATE_DB=state.db

# Change these before exposing the app outside your machine.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
